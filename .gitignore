# Python caches
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
.venv/
venv/
env/

# uv cache (optional)
.uv-cache/

# Jupyter
.ipynb_checkpoints/

# Notebook-generated datasets and artifacts (do not commit)
**/notebooks/data/
**/notebooks/artifacts/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Build and packaging
build/
dist/
*.egg-info/

# Project-generated artifacts (capstones/templates)
projects/**/artifacts/
projects/**/data/raw/
projects/**/data/processed/

# Maintainer-only local logs / research (do not commit)
docs/_artifacts/
docs/_research/*
!docs/_research/README.md

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# Editor
.vscode/
.idea/
